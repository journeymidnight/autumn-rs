python/target
python/*.so

# Do NOT ignore perf_baseline*.json — these are checked-in regression gates
# Override root *.json exclusion for tracked config files. The naming
# perf_baseline_${transport}_p${parts}_d${depth}${_shm?}.json comes from
# the 2×2×2 matrix in perf_check.sh.
!perf_baseline*.json

# Claude Code local session state (not part of the project)
.claude/
